{
  "info": {
    "name": "Trendio — Products Module",
    "_postman_id": "trendio-products-v1",
    "description": "Complete products API test suite.\n\n--- TESTING ORDER ---\n1. Admin Login (saves token)\n2. Create Category → Create Product → Add Images → Add Variants\n3. Public: List Products, Filter, Search, Detail\n4. Update + Delete flows\n\n--- SETUP ---\nActivate 'Trendio — Local Dev' environment before running.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },

  "item": [

    {
      "name": "🔐 Setup — Admin Login",
      "item": [
        {
          "name": "Admin Login (saves token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.environment.set('access_token',  json.access);",
                  "pm.environment.set('refresh_token', json.refresh);",
                  "console.log('Admin token saved.');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"{{admin_email}}\",\n  \"password\":   \"{{admin_password}}\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/login/", "host": ["{{base_url}}"], "path": ["auth","login",""] },
            "description": "Login as admin. Auto-saves access_token. Make sure you created a superuser: python manage.py createsuperuser"
          }
        }
      ]
    },

    {
      "name": "📁 Categories",
      "item": [

        {
          "name": "List All Categories",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns array', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.results).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/categories/", "host": ["{{base_url}}"], "path": ["categories",""] },
            "description": "Public — no auth needed."
          }
        },

        {
          "name": "Create Category — Men",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.environment.set('category_slug', json.slug);",
                  "pm.environment.set('category_id',   json.id);",
                  "console.log('Category slug saved:', json.slug);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\":      \"Men\",\n  \"is_active\": true\n}"
            },
            "url": { "raw": "{{base_url}}/categories/", "host": ["{{base_url}}"], "path": ["categories",""] }
          }
        },

        {
          "name": "Create Category — Shirts (child of Men)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.environment.set('shirts_category_id', pm.response.json().id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\":      \"Shirts\",\n  \"parent\":    \"{{category_id}}\",\n  \"is_active\": true\n}"
            },
            "url": { "raw": "{{base_url}}/categories/", "host": ["{{base_url}}"], "path": ["categories",""] }
          }
        },

        {
          "name": "Get Category Detail",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has children array', () => {",
                  "  pm.expect(pm.response.json()).to.have.property('children');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/categories/{{category_slug}}/", "host": ["{{base_url}}"], "path": ["categories","{{category_slug}}",""] }
          }
        },

        {
          "name": "Update Category",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Men's Wear\"\n}" },
            "url": { "raw": "{{base_url}}/categories/{{category_slug}}/", "host": ["{{base_url}}"], "path": ["categories","{{category_slug}}",""] }
          }
        },

        {
          "name": "Create Category — No Auth (expect 403)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 401 or 403', () => { pm.expect(pm.response.code).to.be.oneOf([401,403]); });"]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Unauthorized\"\n}" },
            "url": { "raw": "{{base_url}}/categories/", "host": ["{{base_url}}"], "path": ["categories",""] }
          }
        }
      ]
    },

