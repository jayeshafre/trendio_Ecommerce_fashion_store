            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "image",      "type": "file", "src": "",        "description": "Select any image file from your computer" },
                { "key": "alt_text",   "type": "text", "value": "Classic Oxford Shirt — Front View" },
                { "key": "is_primary", "type": "text", "value": "true" },
                { "key": "order",      "type": "text", "value": "1" }
              ]
