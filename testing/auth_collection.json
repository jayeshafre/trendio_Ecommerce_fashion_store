{
  "info": {
    "name": "Trendio — Auth Module",
    "_postman_id": "trendio-auth-v1",
    "description": "Complete auth API test suite for Trendio backend.\n\nFlow order:\n1. Register\n2. Login → auto-saves tokens\n3. Me (uses saved token)\n4. OTP Send → Verify\n5. Forgot → Reset Password\n6. Change Password\n7. Logout",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "{{base_url}}" },
    { "key": "access",   "value": "" },
    { "key": "refresh",  "value": "" }
  ],
  "item": [

    {
      "name": "🔐 Auth",
      "item": [

        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Has user_id', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('user_id');",
                  "  pm.environment.set('registered_user_id', json.user_id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"{{test_first_name}}\",\n  \"last_name\":  \"{{test_last_name}}\",\n  \"email\":      \"{{test_email}}\",\n  \"phone\":      \"{{test_phone}}\",\n  \"password\":   \"{{test_password}}\",\n  \"password2\":  \"{{test_password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register/",
              "host": ["{{base_url}}"],
              "path": ["auth", "register", ""]
            },
            "description": "Creates a new customer account. Returns user_id and email. Account starts unverified."
          }
        },

        {
          "name": "Register — Duplicate Email (expect 400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400 for duplicate email', () => pm.response.to.have.status(400));",
                  "pm.test('Error mentions already exists', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.detail.toLowerCase()).to.include('already');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"Test\",\n  \"last_name\":  \"User\",\n  \"email\":      \"{{test_email}}\",\n  \"phone\":      \"9000000001\",\n  \"password\":   \"{{test_password}}\",\n  \"password2\":  \"{{test_password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register/",
              "host": ["{{base_url}}"],
              "path": ["auth", "register", ""]
            }
          }
        },

        {
          "name": "Register — Password Mismatch (expect 400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"Test\",\n  \"last_name\":  \"User\",\n  \"email\":      \"mismatch@test.com\",\n  \"phone\":      \"9000000002\",\n  \"password\":   \"SecurePass@1\",\n  \"password2\":  \"WrongPass@1\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register/",
              "host": ["{{base_url}}"],
              "path": ["auth", "register", ""]
            }
          }
        },

        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has access + refresh tokens', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('access');",
                  "  pm.expect(json).to.have.property('refresh');",
                  "  pm.expect(json).to.have.property('user');",
                  "  pm.environment.set('access_token',  json.access);",
                  "  pm.environment.set('refresh_token', json.refresh);",
                  "  pm.environment.set('user_email',    json.user.email);",
                  "  pm.environment.set('user_role',     json.user.role);",
                  "  console.log('Tokens saved to environment.');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\":    \"{{test_email}}\",\n  \"password\": \"{{test_password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login/",
              "host": ["{{base_url}}"],
              "path": ["auth", "login", ""]
            },
            "description": "Authenticates with email + password. Automatically saves access_token and refresh_token to the environment."
          }
        },

        {
          "name": "Login — Wrong Password (expect 400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));",
                  "pm.test('Error detail exists', () => {",
                  "  pm.expect(pm.response.json()).to.have.property('detail');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\":    \"{{test_email}}\",\n  \"password\": \"WrongPassword@999\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login/",
              "host": ["{{base_url}}"],
              "path": ["auth", "login", ""]
            }
          }
        },

        {
          "name": "Me — Get Profile",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns correct user', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.email).to.equal(pm.environment.get('test_email'));",
                  "  pm.expect(json).to.have.property('id');",
                  "  pm.expect(json).to.have.property('role');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/auth/me/",
              "host": ["{{base_url}}"],
              "path": ["auth", "me", ""]
            },
            "description": "Returns current authenticated user's profile."
          }
        },

        {
          "name": "Me — Update Name",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Name updated', () => {",
                  "  pm.expect(pm.response.json().first_name).to.equal('UpdatedName');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"UpdatedName\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/me/",
              "host": ["{{base_url}}"],
              "path": ["auth", "me", ""]
            }
          }
        },

        {
          "name": "Me — Unauthenticated (expect 401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/auth/me/",
              "host": ["{{base_url}}"],
              "path": ["auth", "me", ""]
            }
          }
        },

        {
          "name": "Token Refresh",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('New access token issued', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('access');",
                  "  pm.environment.set('access_token', json.access);",
                  "  console.log('Access token refreshed.');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/token/refresh/",
              "host": ["{{base_url}}"],
              "path": ["auth", "token", "refresh", ""]
            },
            "description": "Uses the refresh token to issue a new access token. Auto-saves the new access token."
          }
        },

        {
          "name": "Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Success message', () => {",
                  "  pm.expect(pm.response.json().message).to.include('logged out');",
                  "});",
                  "pm.environment.unset('access_token');",
                  "pm.environment.unset('refresh_token');",
                  "console.log('Tokens cleared from environment.');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/logout/",
              "host": ["{{base_url}}"],
              "path": ["auth", "logout", ""]
            },
            "description": "Blacklists the refresh token and clears the session. Auto-clears saved tokens."
          }
        }

      ]
    },

    {
      "name": "📱 OTP",
      "item": [

        {
          "name": "Send OTP — Phone (OTP Login)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has expires_in_minutes', () => {",
                  "  pm.expect(pm.response.json()).to.have.property('expires_in_minutes');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"{{test_phone}}\",\n  \"purpose\":    \"otp_login\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/otp/send/",
              "host": ["{{base_url}}"],
              "path": ["auth", "otp", "send", ""]
            },
            "description": "Sends a 6-digit OTP to the phone number. Check Django dev logs for the OTP code (printed when DEBUG=True)."
          }
        },

        {
          "name": "Send OTP — Email (Email Verify)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"{{test_email}}\",\n  \"purpose\":    \"email_verify\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/otp/send/",
              "host": ["{{base_url}}"],
              "path": ["auth", "otp", "send", ""]
            }
          }
        },

        {
          "name": "Verify OTP — OTP Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "if (json.access) {",
                  "  pm.environment.set('access_token',  json.access);",
                  "  pm.environment.set('refresh_token', json.refresh);",
                  "  console.log('OTP login successful. Tokens saved.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"{{test_phone}}\",\n  \"code\":       \"{{otp_code}}\",\n  \"purpose\":    \"otp_login\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/otp/verify/",
              "host": ["{{base_url}}"],
              "path": ["auth", "otp", "verify", ""]
            },
            "description": "⚠️ Set the 'otp_code' environment variable to the code from your Django dev logs before running."
          }
        },

        {
          "name": "Verify OTP — Wrong Code (expect 400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));",
                  "pm.test('Error detail exists', () => {",
                  "  pm.expect(pm.response.json()).to.have.property('detail');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"{{test_phone}}\",\n  \"code\":       \"000000\",\n  \"purpose\":    \"otp_login\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/otp/verify/",
              "host": ["{{base_url}}"],
              "path": ["auth", "otp", "verify", ""]
            }
          }
        }

      ]
    },

    {
      "name": "🔑 Password",
      "item": [

        {
          "name": "Forgot Password",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Always returns 200 (no user enumeration)', () => {",
                  "  pm.expect(pm.response.json()).to.have.property('message');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{test_email}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/password/forgot/",
              "host": ["{{base_url}}"],
              "path": ["auth", "password", "forgot", ""]
            },
            "description": "Sends a 6-digit reset OTP to the email. Always returns 200 even for unknown emails (prevents user enumeration). Check Django logs for the OTP."
          }
        },

        {
          "name": "Forgot Password — Non-existent Email (expect 200)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Still 200 for unknown email', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"nobody@doesnotexist.com\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/password/forgot/",
              "host": ["{{base_url}}"],
              "path": ["auth", "password", "forgot", ""]
            }
          }
        },

        {
          "name": "Reset Password",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Success message', () => {",
                  "  pm.expect(pm.response.json().message).to.include('Password reset');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\":     \"{{test_email}}\",\n  \"otp\":       \"{{otp_code}}\",\n  \"password\":  \"{{new_password}}\",\n  \"password2\": \"{{new_password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/password/reset/",
              "host": ["{{base_url}}"],
              "path": ["auth", "password", "reset", ""]
            },
            "description": "⚠️ Set otp_code from Django logs. Set new_password in environment. After success, run Login again with the new password."
          }
        },

        {
          "name": "Reset Password — Wrong OTP (expect 400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\":     \"{{test_email}}\",\n  \"otp\":       \"000000\",\n  \"password\":  \"NewPass@123\",\n  \"password2\": \"NewPass@123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/password/reset/",
              "host": ["{{base_url}}"],
              "path": ["auth", "password", "reset", ""]
            }
          }
        },

        {
          "name": "Change Password (Authenticated)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Message includes changed', () => {",
                  "  pm.expect(pm.response.json().message).to.include('Password changed');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"current_password\": \"{{test_password}}\",\n  \"new_password\":     \"{{new_password}}\",\n  \"new_password2\":    \"{{new_password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/password/change/",
              "host": ["{{base_url}}"],
              "path": ["auth", "password", "change", ""]
            }
          }
        },

        {
          "name": "Change Password — Wrong Current (expect 400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"current_password\": \"TotallyWrong@1\",\n  \"new_password\":     \"NewPass@123\",\n  \"new_password2\":    \"NewPass@123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/password/change/",
              "host": ["{{base_url}}"],
              "path": ["auth", "password", "change", ""]
            }
          }
        }

      ]
    },

    {
      "name": "🛡️ Security Checks",
      "item": [

