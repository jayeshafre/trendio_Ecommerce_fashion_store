            },
            "url": {
              "raw": "{{base_url}}/auth/token/refresh/",
              "host": ["{{base_url}}"],
              "path": ["auth", "token", "refresh", ""]
            }
          }
        }

      ]
    },

    {
      "name": "📄 API Docs",
      "item": [
        {
          "name": "Swagger UI",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{api_docs_url}}/docs/",
              "host": ["{{api_docs_url}}"],
              "path": ["docs", ""]
            },
            "description": "Opens the Swagger interactive docs."
          }
        },
        {
          "name": "OpenAPI Schema (JSON)",
          "request": {
            "method": "GET",
